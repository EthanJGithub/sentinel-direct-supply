# ============================================================================
# Sentinel — environment. Copy to .env. EVERYTHING is optional: with no keys and
# no peer services, the system runs fully offline on the heuristic provider +
# local keyword RAG + catalog-JSON fallback. Add keys/URLs to light up the real
# stack. (This is the $0 / cost-discipline story from the JD.)
#
# NOTE: keep values on their own line with NO inline comments — dotenv parsers
# (pydantic-settings) read trailing text as part of the value.
# ============================================================================

# provider mode: auto | demo | dev
#   auto = use real keys when present, else heuristic (default)
#   demo = force real models (interview run)
#   dev  = force free/heuristic, never spend credits
PROVIDER_MODE=auto

# frontier models (only needed for the real "demo" run)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Groq (free tier, OpenAI-compatible) — genuine LLM reasoning at $0. Used as the
# middle tier: Anthropic/OpenAI (paid, if set) > Groq (free, real) > heuristic.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

MODEL_REASON=claude-opus-4-8
MODEL_ROUTE=claude-haiku-4-5-20251001
MODEL_EMBED=text-embedding-3-small

# peer services (empty -> in-process fallbacks)
# CATALOG_URL example: http://localhost:8080   (C# system of record)
# MCP_URL example:     http://localhost:7100   (TS MCP tool server)
# DATABASE_URL example: postgresql://sentinel:sentinel@localhost:5432/sentinel
CATALOG_URL=
MCP_URL=
DATABASE_URL=

# C# service reads this (Npgsql format)
CATALOG_DB=Host=localhost;Port=5432;Database=sentinel;Username=sentinel;Password=sentinel

# observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# guardrails
COST_CEILING_USD=0.50

# auth (JWT + RBAC). Change JWT_SECRET in production (the C# service shares it).
# Demo accounts (shown on the login screen), two tenants demonstrate isolation:
#   operator@cedarwood.health / Operator!2026   (cedarwood; run plans)
#   approver@cedarwood.health / Approver!2026   (cedarwood; place orders — the HITL gate)
#   operator@maplewood.health / Maple!2026      (maplewood; separate tenant)
#   admin@sentinel.io         / Admin!2026       (cross-tenant, full access)
# Override the user set with SENTINEL_AUTH_USERS='[{"email","name","role","tenant_id","facility","password"}]'.
JWT_SECRET=dev-secret-change-me-in-prod
JWT_TTL_SECONDS=28800
CORS_ORIGINS=*
RATE_LIMIT_PER_MIN=120
# production posture: refuse to start with the default secret / wildcard CORS
REQUIRE_STRONG_SECRETS=false

# data cache (real CMS/NFPA source downloads)
SENTINEL_DATA_DIR=D:\sentinel-data

# console
VITE_AGENT_URL=http://localhost:8000
